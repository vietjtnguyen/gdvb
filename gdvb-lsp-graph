# ---------------------------------------------------------------------------
# Minimal LSP client over an already-connected duplex socket (JSON-RPC,
# Content-Length framing). gdvb-lsp-graph never spawns the server itself - see the
# module docstring for why that's a wrapper's job, not this file's.
# ---------------------------------------------------------------------------
class LSP:
    def __init__(self, sock):
        self.sock = sock
        self._id = 0
        # Some servers (clangd) report indexing progress via $/progress; others
        # may report none at all. Track activity generically (see wait_for_ready)
        # rather than assuming any one server's specific progress-token shape.
        self._last_progress = None
        # clangd 14's typeHierarchy has known crash bugs (segfaults on some real
        # code - confirmed against orchard/) that take down the whole process, not
        # just one request. Once that happens (the socket errors/closes), stop
        # writing and treat every further request as "no data" instead of
        # raising, so a whole-project run keeps whatever it already collected
        # rather than crashing.
        self.crashed = False
        self._warned = False

    def _warn_crashed(self):
        if not self._warned:
            self._warned = True
            sys.stderr.write(
                "gdvb-lsp-graph: warning: the language server connection closed "
                "unexpectedly (some servers, e.g. clangd's typeHierarchy, have "
                "known crash bugs on certain code); continuing with what was "
                "already collected\n"
            )

    def _frame(self, obj):
        if self.crashed:
            return
        body = json.dumps(obj).encode()
        try:
            self.sock.sendall(b"Content-Length: %d\r\n\r\n" % len(body) + body)
        except OSError:
            self.crashed = True
            self._warn_crashed()

    def send(self, method, params):
        self._id += 1
        self._frame(
            {"jsonrpc": "2.0", "id": self._id, "method": method, "params": params}
        )
        return self._id

    def notify(self, method, params):
        self._frame({"jsonrpc": "2.0", "method": method, "params": params})

    def _recv(self, n, deadline):
        """Read exactly n bytes, or None on timeout/EOF/error."""
        buf = b""
        while len(buf) < n:
            if time.time() > deadline:
                return None
            r, _, _ = select.select([self.sock], [], [], max(0, deadline - time.time()))
            if not r:
                return None
            try:
                chunk = self.sock.recv(n - len(buf))
            except OSError:
                return None
            if not chunk:
                return None
            buf += chunk
        return buf

    def _read_msg(self, deadline):
        if self.crashed:
            return None
        buf = b""
        while b"\r\n\r\n" not in buf:
            got = self._recv(1, deadline)
            if got is None:
                return None
            buf += got
        header, rest = buf.split(b"\r\n\r\n", 1)
        n = int(
            dict(
                line.split(b": ", 1) for line in header.split(b"\r\n") if b": " in line
            )[b"Content-Length"]
        )
        body = rest
        remaining = self._recv(n - len(rest), deadline) if n > len(rest) else b""
        if remaining is None:
            return None
        body += remaining
        return json.loads(body)

    def _handle(self, m):
        """Dispatch a non-response message. Returns True if it was server noise
        (a server->client request we answered, or a notification)."""
        if "id" in m and "method" in m:  # server -> client request: answer null
            res = [None] if m["method"] == "workspace/configuration" else None
            self._frame({"jsonrpc": "2.0", "id": m["id"], "result": res})
            return True
        if m.get("method") == "$/progress":
            self._last_progress = time.time()
            return True
        return "method" in m  # other notifications are noise too

    def wait_for(self, rid, timeout=30):
        if self.crashed:
            return None
        deadline = time.time() + timeout
        while True:
            m = self._read_msg(deadline)
            if m is None:
                if not self.crashed:
                    self.crashed = True
                    self._warn_crashed()
                return None
            if m.get("id") == rid and "result" in m:
                return m["result"]
            if m.get("id") == rid and "error" in m:
                return None
            self._handle(m)

    def request(self, method, params, timeout=30):
        return self.wait_for(self.send(method, params), timeout)

    def wait_for_ready(self, total_timeout, quiet=2.0):
        """Generic index-warmup wait: after opening the files it's about to
        query, a client has no portable way to know when a server's background
        indexing (if any) has settled - LSP's $/progress carries no server-
        agnostic "this is THE index task" marker. So: pump messages, and stop
        once `quiet` seconds pass with no new $/progress activity (covers
        servers that report progress, e.g. clangd), falling back to the flat
        `total_timeout` if the server never reports any progress at all."""
        deadline = time.time() + total_timeout
        self._last_progress = None
        quiet_until = time.time() + quiet
        while time.time() < deadline:
            m = self._read_msg(min(quiet_until, deadline))
            if m is None:
                if time.time() >= quiet_until:
                    return
                continue
            self._handle(m)
            if self._last_progress is not None:
                quiet_until = self._last_progress + quiet

    def shutdown(self):
        try:
            self.send("shutdown", {})
            self.notify("exit", {})
        except Exception:
            pass
        try:
            self.sock.close()
        except OSError:
            pass


# ---------------------------------------------------------------------------
# Call-graph walk
# ---------------------------------------------------------------------------
def _uri(path):
    return "file://" + os.path.abspath(path)


def _path(uri):
    return uri[len("file://") :] if uri.startswith("file://") else uri


def _flatten(symbols, out):
    for s in symbols or []:
        out.append(s)
        _flatten(s.get("children"), out)


def _flatten_with_parent(symbols, parent, out):
    for s in symbols or []:
        out.append((s, parent))
        _flatten_with_parent(s.get("children"), s, out)


# File extension -> LSP languageId. gdvb-lsp-graph is LSP-generic (any server speaking
# textDocument/documentSymbol + callHierarchy works); this table is what lets
# --all and didOpen work across languages instead of assuming C++.
LANG_BY_EXT = {
    ".c": "c",
    ".h": "c",
    ".cc": "cpp",
    ".cpp": "cpp",
    ".cxx": "cpp",
    ".hpp": "cpp",
    ".hh": "cpp",
    ".inl": "cpp",
    ".py": "python",
    ".pyi": "python",
    ".go": "go",
    ".rs": "rust",
    ".ts": "typescript",
    ".tsx": "typescriptreact",
    ".js": "javascript",
    ".jsx": "javascriptreact",
    ".java": "java",
}
_SOURCE_EXTS = tuple(LANG_BY_EXT)


def _shebang_lang(path):
    """For an extensionless script (this project's OWN convention: kebab-case,
    no .py - see gdvb-lsp-graph itself), sniff the shebang for a known interpreter,
    since extension-based language_id() has nothing to go on."""
    try:
        with open(path, "rb") as fh:
            first = fh.readline(200)
    except OSError:
        return None
    if not first.startswith(b"#!"):
        return None
    first = first.decode("utf-8", "replace")
    if "python" in first:
        return "python"
    return None


def language_id(path):
    ext = os.path.splitext(path)[1]
    if ext in LANG_BY_EXT:
        return LANG_BY_EXT[ext]
    return _shebang_lang(path) or "plaintext"


# Common vendored-dependency directory names: --all is meant to graph the
# project's OWN code, and a single vendored header (e.g. a single-header JSON
# library) can be tens of thousands of lines - scanning it would dominate the
# runtime and bury the project's own symbols. Not exhaustive (a vendored lib
# dropped in under an unrecognized name won't be caught) - see --exclude-dir.
_SKIP_DIRS = {
    ".git",
    "node_modules",
    ".cache",
    "third_party",
    "thirdparty",
    "vendor",
    "external",
    "extern",
    "deps",
}


def discover_source_files(root, extra_skip_dirs=()):
    """Every known-language source/header under `root`, skipping VCS/build/
    vendor dirs. Used by --all to enumerate what to open+documentSymbol for a
    whole-project scan - deliberately a directory walk, not e.g.
    compile_commands.json's TU list, since headers (where most C++ classes
    live) aren't their own compiled TU. Extensionless scripts with a
    recognized shebang are included too (this project's own convention)."""
    skip = _SKIP_DIRS | set(extra_skip_dirs)
    out = []
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [
            d for d in dirnames if d not in skip and not d.startswith((".", "build"))
        ]
        for fn in filenames:
            path = os.path.join(dirpath, fn)
            if fn.endswith(_SOURCE_EXTS):
                out.append(path)
            elif "." not in fn and _shebang_lang(path):
                out.append(path)
    return sorted(out)


def build_callgraph(
    lsp,
    root,
    seed_names,
    seed_files,
    seed_all,
    exclude_dirs,
    direction,
    depth,
    max_nodes,
    index_timeout,
    type_depth,
    has_type_hierarchy,
):
    opened = set()

    def open_file(path):
        if path in opened or not os.path.exists(path):
            return
        opened.add(path)
        text = open(path, encoding="utf-8", errors="replace").read()
        lsp.notify(
            "textDocument/didOpen",
            {
                "textDocument": {
                    "uri": _uri(path),
                    "languageId": language_id(path),
                    "version": 1,
                    "text": text,
                }
            },
        )

    # Some servers (clangd) only start background-indexing once a file is open.
    # Open the seed files first (for --seed-only runs, open any project source
    # as a kick) so indexing begins, THEN wait for it - call hierarchy needs it.
    kick = list(seed_files)
    if not kick and seed_names:
        cand = discover_source_files(root, exclude_dirs)
        if cand:
            kick = [cand[0]]
    for p in kick:
        open_file(p)
    sys.stderr.write("gdvb-lsp-graph: waiting for background index...\n")
    lsp.wait_for_ready(index_timeout)
    time.sleep(0.5)

    def itemkey(item):
        s = item["selectionRange"]["start"]
        return "%s:%d:%d" % (item["uri"], s["line"], s["character"])

    nodes = {}  # itemkey (or "type:"+key) -> node dict, shared namespace
    edges = {}  # (src_id, tgt_id) -> edge dict

    # ---- type containment (documentSymbol) + inheritance (typeHierarchy) ----
    scanned_files = set()
    container_map = {}  # member itemkey -> (parent symbol dict, uri)
    discovered = []  # (symbol, uri) for every callable/type seen - --all seeding
    pending_type_expansion = []  # (node, sym, uri) - typeHierarchy calls, deferred

    def scan_file(path):
        """Cache the file's containment structure: for every method/ctor/function
        nested under a class/struct/interface/enum, remember its owner. clangd's
        CallHierarchyItem carries no parent-symbol info, so this is the only way
        to recover "what type does this callable belong to". Also records every
        callable/type symbol seen into `discovered`, for --all's whole-project
        seeding (a no-op list when --all isn't requested)."""
        if path in scanned_files or not os.path.exists(path):
            return
        scanned_files.add(path)
        open_file(path)
        uri = _uri(path)
        pairs = []
        _flatten_with_parent(
            lsp.request("textDocument/documentSymbol", {"textDocument": {"uri": uri}}),
            None,
            pairs,
        )
        for sym, parent in pairs:
            kind = sym.get("kind")
            if kind in KIND_CLASS or kind in TYPE_KIND_CLASS:
                discovered.append((sym, uri))
            if (
                parent is not None
                and kind in KIND_CLASS
                and parent.get("kind") in TYPE_KIND_CLASS
            ):
                s = sym["selectionRange"]["start"]
                key = "%s:%d:%d" % (uri, s["line"], s["character"])
                container_map[key] = (parent, uri)

    def type_node_for(sym, uri):
        s = sym["selectionRange"]["start"]
        key = "type:%s:%d:%d" % (uri, s["line"], s["character"])
        if key in nodes:
            return nodes[key]
        rel = os.path.relpath(_path(uri), root)
        cls = [TYPE_KIND_CLASS.get(sym.get("kind"), "class")]
        tid = "type:%s:%d:%d:%s" % (rel, s["line"], s["character"], sym["name"])
        node = {
            "id": tid,
            "label": sym["name"],
            "full": "%s\n%s:%d" % (sym["name"], rel, s["line"] + 1),
            "classes": cls,
        }
        nodes[key] = node
        # Deferred, not called here: typeHierarchy is an RPC that clangd 14 is
        # known to crash on for some real code (confirmed against orchard/), and
        # a crash takes down the whole process. Running every expansion only
        # after the call graph (the primary output) is fully built means a crash
        # here can only cost inheritance edges, never already-collected calls.
        # Skipped entirely (no requests at all) if the server never advertised
        # typeHierarchyProvider (e.g. pyright - confirmed it doesn't support
        # type hierarchy at all, only call hierarchy).
        if has_type_hierarchy:
            pending_type_expansion.append((node, sym, uri))
        return node

    def _std_type_chain(item, key, remaining):
        """Standardized LSP 3.17 typeHierarchy/supertypes|subtypes only return
        one hop per call, unlike clangd's legacy extension - so recurse up to
        `remaining` hops here, attaching each further hop under the same `key`
        clangd's shape uses ("parents" or "children"), so _walk_type_edges can
        consume either source uniformly."""
        method = (
            "typeHierarchy/supertypes" if key == "parents" else "typeHierarchy/subtypes"
        )
        results = lsp.request(method, {"item": item}) or []
        out = []
        for r in results:
            r = dict(r)
            if remaining > 1:
                r[key] = _std_type_chain(r, key, remaining - 1)
            out.append(r)
        return out

    def expand_type_hierarchy(node, sym, uri):
        pos = sym["selectionRange"]["start"]
        # Try the standardized prepareTypeHierarchy/supertypes/subtypes trio
        # first (LSP 3.17); fall back to clangd's pre-standardization extension
        # (a single request returns the whole parents/children chain, pre-
        # resolved to `resolve` levels deep, inline) - same generation gap as
        # callHierarchy/incomingCalls-only. Only reached when the server
        # advertised typeHierarchyProvider at all (see type_node_for).
        prepared = lsp.request(
            "textDocument/prepareTypeHierarchy",
            {"textDocument": {"uri": uri}, "position": pos},
        )
        if prepared:
            item = prepared[0]
            result = {
                "parents": _std_type_chain(item, "parents", type_depth),
                "children": _std_type_chain(item, "children", type_depth),
            }
        else:
            result = lsp.request(
                "textDocument/typeHierarchy",
                {
                    "textDocument": {"uri": uri},
                    "position": pos,
                    "direction": 2,  # Both (0=Children, 1=Parents, 2=Both)
                    "resolve": type_depth,
                },
            )
        if not result:
            return
        _walk_type_edges(result.get("parents"), node, True)
        _walk_type_edges(result.get("children"), node, False)

    def _walk_type_edges(items, from_node, is_super):
        # `items` is already recursively resolved by clangd (nested parents/
        # children inline), so this just flattens it - no further RPCs.
        for it in items or []:
            if len(nodes) >= max_nodes:
                return
            it_uri = it.get("uri")
            s = it["selectionRange"]["start"]
            key = "type:%s:%d:%d" % (it_uri, s["line"], s["character"])
            tnode = nodes.get(key)
            if tnode is None:
                rel = os.path.relpath(_path(it_uri), root)
                cls = [TYPE_KIND_CLASS.get(it.get("kind"), "class")]
                tid = "type:%s:%d:%d:%s" % (rel, s["line"], s["character"], it["name"])
                tnode = {
                    "id": tid,
                    "label": it["name"],
                    "full": "%s\n%s:%d" % (it["name"], rel, s["line"] + 1),
                    "classes": cls,
                }
                nodes[key] = tnode
            src, tgt = (
                (from_node["id"], tnode["id"])
                if is_super
                else (tnode["id"], from_node["id"])
            )
            edges.setdefault(
                (src, tgt),
                {
                    "source": src,
                    "target": tgt,
                    "label": "inherits",
                    "classes": ["inherits"],
                },
            )
            _walk_type_edges(it.get("parents"), tnode, True)
            _walk_type_edges(it.get("children"), tnode, False)

    def link_container(item, member_node):
        path = _path(item["uri"])
        scan_file(path)
        entry = container_map.get(itemkey(item))
        if not entry:
            return
        parent_sym, uri = entry
        tnode = type_node_for(parent_sym, uri)
        edges.setdefault(
            (member_node["id"], tnode["id"]),
            {
                "source": member_node["id"],
                "target": tnode["id"],
                "label": "member of",
                "classes": ["member-of"],
            },
        )

    def node_for(item, seed=False):
        key = itemkey(item)
        if key in nodes:
            if seed and "seed" not in nodes[key]["classes"]:
                nodes[key]["classes"].append("seed")
            return nodes[key]
        rel = os.path.relpath(_path(item["uri"]), root)
        s = item["selectionRange"]["start"]
        cls = [KIND_CLASS.get(item.get("kind"), "function")]
        if seed:
            cls.append("seed")
        nid = "sym:%s:%d:%d:%s" % (rel, s["line"], s["character"], item["name"])
        detail = item.get("detail") or ""
        node = {
            "id": nid,
            "label": item["name"],
            "full": "%s\n%s\n%s:%d" % (item["name"], detail, rel, s["line"] + 1),
            "classes": cls,
        }
        nodes[key] = node
        link_container(item, node)
        return node

    # Resolve seeds -> CallHierarchyItems.
    seeds = []
    for path in seed_files:
        if not os.path.exists(path):
            sys.stderr.write("gdvb-lsp-graph: no such file: %s\n" % path)
            continue
        open_file(path)
        syms = []
        _flatten(
            lsp.request(
                "textDocument/documentSymbol", {"textDocument": {"uri": _uri(path)}}
            ),
            syms,
        )
        for sym in syms:
            if sym.get("kind") not in KIND_CLASS:
                continue
            pos = sym["selectionRange"]["start"]
            items = lsp.request(
                "textDocument/prepareCallHierarchy",
                {"textDocument": {"uri": _uri(path)}, "position": pos},
            )
            seeds.extend(items or [])
    for name in seed_names:
        for sym in lsp.request("workspace/symbol", {"query": name}) or []:
            if sym.get("kind") not in KIND_CLASS:
                continue
            loc = sym.get("location", {})
            uri = loc.get("uri")
            if not uri:
                continue
            open_file(_path(uri))
            items = lsp.request(
                "textDocument/prepareCallHierarchy",
                {"textDocument": {"uri": uri}, "position": loc["range"]["start"]},
            )
            seeds.extend(items or [])

    # --all: open+documentSymbol every source file under the project, adding every
    # callable as a bulk (unmarked) BFS start and every type directly (so a bare
    # enum/struct with no methods still gets a node, not just incidental ones
    # discovered via containment).
    bulk_items = []
    if seed_all:
        files = discover_source_files(root, exclude_dirs)
        sys.stderr.write(
            "gdvb-lsp-graph: --all: scanning %d source file(s)...\n" % len(files)
        )
        for path in files:
            scan_file(path)
        for sym, uri in discovered:
            kind = sym.get("kind")
            if kind in KIND_CLASS:
                # Ask the server for a real CallHierarchyItem rather than
                # hand-rolling one from raw documentSymbol data: a hand-rolled
                # dict is missing fields (e.g. `range`) a real item has, and
                # while clangd tolerates that, pyright silently no-ops on
                # incomingCalls/outgoingCalls for a malformed item (confirmed -
                # zero call edges came back until this was fixed).
                items = lsp.request(
                    "textDocument/prepareCallHierarchy",
                    {
                        "textDocument": {"uri": uri},
                        "position": sym["selectionRange"]["start"],
                    },
                )
                bulk_items.extend(items or [])
            elif kind in TYPE_KIND_CLASS:
                type_node_for(sym, uri)

    if not seeds and not bulk_items:
        raise SystemExit(
            "gdvb-lsp-graph: no seed symbols resolved (check --seed/--file/--all)"
        )

    # BFS up the caller graph via incomingCalls. Explicit seeds get the red
    # "seed" border; --all's bulk items don't (marking every symbol in the
    # project as "the seed" would be meaningless noise).
    queue = []
    visited = set()
    for it in seeds:
        node_for(it, seed=True)
        k = itemkey(it)
        if k not in visited:
            visited.add(k)
            queue.append((it, 0))
    for it in bulk_items:
        node_for(it, seed=False)
        k = itemkey(it)
        if k not in visited:
            visited.add(k)
            queue.append((it, 0))

    while queue and len(nodes) < max_nodes:
        item, d = queue.pop(0)
        if d >= depth:
            continue
        open_file(_path(item["uri"]))
        origin = node_for(item)
        if direction in ("in", "both"):
            incoming = lsp.request("callHierarchy/incomingCalls", {"item": item}) or []
            for call in incoming:
                frm = call.get("from")
                if not frm:
                    continue
                if itemkey(frm) not in nodes and len(nodes) >= max_nodes:
                    continue  # don't add new caller nodes past the cap
                caller = node_for(frm)
                edges[(caller["id"], origin["id"])] = {
                    "source": caller["id"],
                    "target": origin["id"],
                    "label": "calls",
                    "classes": ["call"],
                }
                k = itemkey(frm)
                if k not in visited and len(nodes) < max_nodes:
                    visited.add(k)
                    queue.append((frm, d + 1))
        if direction in ("out", "both"):
            # Only meaningful on servers implementing outgoingCalls (clangd 14
            # doesn't - it always returns empty here, a harmless no-op).
            outgoing = lsp.request("callHierarchy/outgoingCalls", {"item": item}) or []
            for call in outgoing:
                to = call.get("to")
                if not to:
                    continue
                if itemkey(to) not in nodes and len(nodes) >= max_nodes:
                    continue  # don't add new callee nodes past the cap
                callee = node_for(to)
                edges[(origin["id"], callee["id"])] = {
                    "source": origin["id"],
                    "target": callee["id"],
                    "label": "calls",
                    "classes": ["call"],
                }
                k = itemkey(to)
                if k not in visited and len(nodes) < max_nodes:
                    visited.add(k)
                    queue.append((to, d + 1))

    # Now that the call graph is fully built, resolve every type's ancestors/
    # descendants. Deferred to last (see type_node_for) so a typeHierarchy crash
    # can only truncate inherits edges, not the call graph above.
    for node, sym, uri in pending_type_expansion:
        if len(nodes) >= max_nodes:
            break
        expand_type_hierarchy(node, sym, uri)

    truncated = bool(queue) or len(nodes) >= max_nodes
    return list(nodes.values()), list(edges.values()), truncated


def assemble(nodes, edges, root, seeds_desc, truncated):
    counts = {"nodes": len(nodes), "edges": len(edges), "by_type": {}, "by_class": {}}
    for n in nodes:
        for c in n["classes"]:
            counts["by_type"][c] = counts["by_type"].get(c, 0) + 1
    for e in edges:
        for c in e["classes"]:
            counts["by_class"][c] = counts["by_class"].get(c, 0) + 1
    meta = {
        "title": "calls — " + os.path.basename(os.path.abspath(root)),
        "subtitle": "seeded from " + seeds_desc,
        "host": socket.gethostname(),
        "captured": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
        "truncated": truncated,
        "counts": counts,
    }
    return {
        "meta": meta,
        "node_classes": NODE_CLASSES,
        "edge_classes": EDGE_CLASSES,
        "style": STYLE,
        "edge_key": EDGE_KEY,
        "traversals": TRAVERSALS,
        "force_structures": FORCE_STRUCTURES,
        "nodes": nodes,
        "edges": edges,
    }


def main():
    ap = argparse.ArgumentParser(
        prog="gdvb-lsp-graph",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description=(
            "Low-level LSP client: connect to an ALREADY-RUNNING language server\n"
            "over a Unix domain socket and emit a call-graph model JSON for the\n"
            "gdvb viewer. Normally you don't run this directly - use a\n"
            "per-server wrapper (gdvb-clangd-lsp-graph, gdvb-pyright-lsp-graph) that starts\n"
            "the server, bridges it to a socket, and calls this for you."
        ),
        epilog=(
            "examples (normal usage - via a wrapper):\n"
            "  gdvb-clangd-lsp-graph proj --file src/foo.cpp | gdvb-render > c.html\n"
            "  gdvb-pyright-lsp-graph proj --all --max-nodes 5000 | gdvb-render\n"
            "\ndirect usage (already have a server on a socket):\n"
            "  gdvb-lsp-graph proj --connect /tmp/lsp.sock --seed planPath --depth 4\n"
        ),
    )
    ap.add_argument("project", help="project root")
    ap.add_argument(
        "--connect",
        required=True,
        metavar="PATH",
        help="Unix domain socket path an already-running language server is "
        "reachable on (see wrapper scripts, e.g. gdvb-clangd-lsp-graph)",
    )
    ap.add_argument(
        "--seed",
        action="append",
        default=[],
        metavar="NAME",
        help="seed symbol name (workspace/symbol); repeatable",
    )
    ap.add_argument(
        "--file",
        action="append",
        default=[],
        metavar="PATH",
        help="seed from every function in PATH; repeatable",
    )
    ap.add_argument(
        "--all",
        action="store_true",
        help="seed from every function/type in the project (walks every source "
        "file's documentSymbol) for a whole-project graph; combine with a "
        "larger --max-nodes",
    )
    ap.add_argument(
        "--exclude-dir",
        action="append",
        default=[],
        metavar="NAME",
        help="with --all, also skip this directory name (repeatable); "
        "third_party/vendor/etc. are already skipped by default",
    )
    ap.add_argument(
        "--depth",
        type=int,
        default=3,
        metavar="N",
        help="caller BFS hops from the seeds (default: 3)",
    )
    ap.add_argument(
        "--direction",
        choices=["in", "out", "both"],
        default="in",
        help="walk callers (in, the impact direction - default), callees "
        "(out), or both. clangd 14 only implements incomingCalls (in); "
        "servers with full call hierarchy (e.g. pyright) support out/both",
    )
    ap.add_argument(
        "--max-nodes",
        type=int,
        default=400,
        metavar="N",
        help="cap total symbols (default: 400)",
    )
    ap.add_argument(
        "--type-depth",
        type=int,
        default=3,
        metavar="N",
        help="ancestor/descendant hops to resolve per type via typeHierarchy (default: 3)",
    )
    ap.add_argument(
        "--index-timeout",
        type=int,
        default=60,
        metavar="S",
        help="max seconds to wait for the server to settle after opening seed "
        "files, before assuming it's ready (default: 60)",
    )
    args = ap.parse_args()

    project = os.path.abspath(args.project)
    if not os.path.isdir(project):
        ap.error("not a directory: %s" % args.project)
    if not args.seed and not args.file and not args.all:
        ap.error("give at least one --seed NAME, --file PATH, or --all")

    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.connect(args.connect)
    except OSError as e:
        raise SystemExit("gdvb-lsp-graph: cannot connect to %s: %s" % (args.connect, e))

    lsp = LSP(sock)
    try:
        ok = lsp.request(
            "initialize",
            {
                "processId": os.getpid(),
                "rootUri": _uri(project),
                "capabilities": {
                    "textDocument": {
                        "callHierarchy": {"dynamicRegistration": True},
                        "typeHierarchy": {"dynamicRegistration": True},
                        "documentSymbol": {"hierarchicalDocumentSymbolSupport": True},
                    },
                    "window": {"workDoneProgress": True},
                },
            },
        )
        if ok is None:
            raise SystemExit("gdvb-lsp-graph: server failed to initialize")
        lsp.notify("initialized", {})
        has_type_hierarchy = bool(
            (ok.get("capabilities") or {}).get("typeHierarchyProvider")
        )

        # --file may be given relative to cwd or to the project root.
        seed_files = [
            os.path.abspath(p if os.path.exists(p) else os.path.join(project, p))
            for p in args.file
        ]
        nodes, edges, truncated = build_callgraph(
            lsp,
            project,
            args.seed,
            seed_files,
            args.all,
            args.exclude_dir,
            args.direction,
            args.depth,
            args.max_nodes,
            args.index_timeout,
            args.type_depth,
            has_type_hierarchy,
        )
    finally:
        lsp.shutdown()

    seeds_desc = ", ".join(args.seed + [os.path.basename(p) for p in args.file])
    if args.all:
        seeds_desc = (seeds_desc + ", " if seeds_desc else "") + "whole project (--all)"
    seeds_desc = seeds_desc or "?"
    model = assemble(nodes, edges, project, seeds_desc, truncated)
    json.dump(model, sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
    c = model["meta"]["counts"]
    sys.stderr.write(
        "gdvb-lsp-graph: %s — %d nodes, %d edges%s\n"
        % (
            model["meta"]["title"],
            c["nodes"],
            c["edges"],
            " [truncated]" if truncated else "",
        )
    )


if __name__ == "__main__":
    main()
