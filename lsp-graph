#!/usr/bin/env python3
"""lsp-graph - emit a symbol call graph from a language server, as JSON.

A standalone generator for the socketscope viewer. It drives a language server
(clangd by default) over stdio JSON-RPC, walks the CALL HIERARCHY outward from
one or more seed symbols, and prints ONE JSON graph model to stdout - the same
generic model the other generators produce. It does NOT import render-graph-html.py;
the JSON model is the only contract. Pipe it to the viewer:

    lsp-graph <project> --file src/foo.cpp | render-graph-html.py > calls.html
    lsp-graph <project> --seed planPath   | render-graph-html.py > calls.html
    lsp-graph <project> --all --max-nodes 5000 | render-graph-html.py > calls.html

The graph is built from `callHierarchy/incomingCalls` (who calls X), walking UP
the call graph from the seeds - the impact-analysis direction ("what breaks if I
change this"). Edges are directed caller->callee, so the viewer navigates either
way. (clangd 14 doesn't implement outgoingCalls; callers are what's available.)

Every method/constructor discovered also pulls in its OWNING TYPE (class/struct/
interface/enum) as a first-class node, via `textDocument/documentSymbol`
containment - a `member-of` edge from the callable to its type. Each type then
resolves its ancestors/descendants via `textDocument/typeHierarchy` (clangd's
pre-3.17 extension - clangd 14 doesn't speak the standardized
prepareTypeHierarchy/supertypes/subtypes trio) into `inherits` edges
(derived->base), bounded by `--type-depth` hops.

`--all` seeds from every function/type in the project instead of a specific
--seed/--file: it walks every source file under the project root (documentSymbol,
not compile_commands.json's TU list, since headers - where most classes live -
aren't their own translation unit) and adds every callable/type it finds, without
the `seed` border (marking everything "the seed" is meaningless). Combine with a
larger --max-nodes; the default (400) truncates quickly on a whole project.

Requires the language server on PATH (clangd >= the call-hierarchy versions) and,
for clangd, a compile_commands.json. Stdlib only.
"""
import os
import sys
import glob
import json
import time
import select
import socket
import argparse
import datetime
import subprocess

# LSP SymbolKind -> our node class, for the callables the call-hierarchy walk seeds
# from and returns.
KIND_CLASS = {6: "method", 9: "constructor", 12: "function"}

# LSP SymbolKind -> our node class, for the *containers* a callable belongs to
# (class/struct/interface/enum). These aren't call-hierarchy seeds; they're
# discovered incidentally via documentSymbol containment and typeHierarchy.
TYPE_KIND_CLASS = {5: "class", 23: "struct", 11: "interface", 10: "enum"}

