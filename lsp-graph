# ---------------------------------------------------------------------------
# Minimal LSP client over a server's stdio (JSON-RPC, Content-Length framing)
# ---------------------------------------------------------------------------
class LSP:
    def __init__(self, cmd):
        try:
            self.proc = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                bufsize=0,
            )
        except FileNotFoundError:
            raise SystemExit("lsp-graph: language server not found: %s" % cmd[0])
        self._id = 0
        self.index_done = False
        self._index_token = None
        # clangd 14's typeHierarchy has known crash bugs (segfaults on some real
        # code - confirmed against orchard/) that take down the whole process, not
        # just one request. Once that happens, stop writing to the dead pipe and
        # treat every further request as "no data" instead of raising, so a whole
        # -project run keeps whatever it already collected rather than crashing.
        self.crashed = False
        self._warned = False

    def _warn_crashed(self):
        if not self._warned:
            self._warned = True
            sys.stderr.write(
                "lsp-graph: warning: the language server exited unexpectedly "
                "(clangd's typeHierarchy has known crash bugs on some code); "
                "continuing with what was already collected\n"
            )

    def _frame(self, obj):
        if self.crashed:
            return
        body = json.dumps(obj).encode()
        try:
            self.proc.stdin.write(b"Content-Length: %d\r\n\r\n" % len(body) + body)
            self.proc.stdin.flush()
        except (BrokenPipeError, OSError):
            self.crashed = True
            self._warn_crashed()

    def send(self, method, params):
        self._id += 1
        self._frame(
            {"jsonrpc": "2.0", "id": self._id, "method": method, "params": params}
        )
        return self._id

    def notify(self, method, params):
        self._frame({"jsonrpc": "2.0", "method": method, "params": params})

    def _read_msg(self, deadline):
        buf = b""
        while b"\r\n\r\n" not in buf:
            if time.time() > deadline:
                return None
            r, _, _ = select.select(
                [self.proc.stdout], [], [], max(0, deadline - time.time())
            )
            if not r:
                return None
            c = self.proc.stdout.read(1)
            if not c:
                return None
            buf += c
        header, rest = buf.split(b"\r\n\r\n", 1)
        n = int(
            dict(
                line.split(b": ", 1) for line in header.split(b"\r\n") if b": " in line
            )[b"Content-Length"]
        )
        body = rest
        while len(body) < n:
            if time.time() > deadline:
                return None
            r, _, _ = select.select(
                [self.proc.stdout], [], [], max(0, deadline - time.time())
            )
            if not r:
                return None
            chunk = self.proc.stdout.read(n - len(body))
            if not chunk:
                return None
            body += chunk
        return json.loads(body)

    def _handle(self, m):
        """Dispatch a non-response message. Returns True if it was server noise
        (a server->client request we answered, or a notification)."""
        if "id" in m and "method" in m:  # server -> client request: answer null
            res = [None] if m["method"] == "workspace/configuration" else None
            self._frame({"jsonrpc": "2.0", "id": m["id"], "result": res})
            return True
        if m.get("method") == "$/progress":
            v = m.get("params", {}).get("value", {})
            tok = m.get("params", {}).get("token")
            # clangd starts its (one) background-index progress once a file is
            # opened. Latch the first begin as the index token and complete only
            # on that token's end, so a stray task can't end the wait early.
            if v.get("kind") == "begin" and self._index_token is None:
                self._index_token = tok
            elif v.get("kind") == "end" and tok == self._index_token:
                self.index_done = True
            return True
        return "method" in m  # other notifications are noise too

    def wait_for(self, rid, timeout=30):
        if self.crashed:
            return None
        deadline = time.time() + timeout
        while True:
            m = self._read_msg(deadline)
            if m is None:
                if self.proc.poll() is not None:
                    self.crashed = True
                    self._warn_crashed()
                return None
            if m.get("id") == rid and "result" in m:
                return m["result"]
            if m.get("id") == rid and "error" in m:
                return None
            self._handle(m)

    def request(self, method, params, timeout=30):
        return self.wait_for(self.send(method, params), timeout)

    def pump(self, seconds, until_index=False):
        deadline = time.time() + seconds
        while time.time() < deadline:
            m = self._read_msg(deadline)
            if m is None:
                break
            self._handle(m)
            if until_index and self.index_done:
                break

    def shutdown(self):
        try:
            self.send("shutdown", {})
            self.notify("exit", {})
        except Exception:
            pass
        self.proc.terminate()


# ---------------------------------------------------------------------------
# Call-graph walk
# ---------------------------------------------------------------------------
def _uri(path):
    return "file://" + os.path.abspath(path)


def _path(uri):
    return uri[len("file://") :] if uri.startswith("file://") else uri


def _flatten(symbols, out):
    for s in symbols or []:
        out.append(s)
        _flatten(s.get("children"), out)


def _flatten_with_parent(symbols, parent, out):
    for s in symbols or []:
        out.append((s, parent))
        _flatten_with_parent(s.get("children"), s, out)


_SOURCE_EXTS = (".c", ".cc", ".cpp", ".cxx", ".h", ".hpp", ".hh", ".inl")
# Common vendored-dependency directory names: --all is meant to graph the
# project's OWN code, and a single vendored header (e.g. a single-header JSON
# library) can be tens of thousands of lines - scanning it would dominate the
# runtime and bury the project's own symbols. Not exhaustive (a vendored lib
# dropped in under an unrecognized name won't be caught) - see --exclude-dir.
_SKIP_DIRS = {
    ".git",
    "node_modules",
    ".cache",
    "third_party",
    "thirdparty",
    "vendor",
    "external",
    "extern",
    "deps",
}


def discover_source_files(root, extra_skip_dirs=()):
    """Every C/C++ source/header under `root`, skipping VCS/build/vendor dirs.
    Used by --all to enumerate what to open+documentSymbol for a whole-project
    scan - deliberately a directory walk, not compile_commands.json's TU list,
    since headers (where most classes live) aren't their own compiled TU."""
    skip = _SKIP_DIRS | set(extra_skip_dirs)
    out = []
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [
            d for d in dirnames if d not in skip and not d.startswith((".", "build"))
        ]
        for fn in filenames:
            if fn.endswith(_SOURCE_EXTS):
                out.append(os.path.join(dirpath, fn))
    return sorted(out)


def build_callgraph(
    lsp,
    root,
    seed_names,
    seed_files,
    seed_all,
    exclude_dirs,
    depth,
    max_nodes,
    index_timeout,
    type_depth,
):
    opened = set()

    def open_file(path):
        if path in opened or not os.path.exists(path):
            return
        opened.add(path)
        text = open(path, encoding="utf-8", errors="replace").read()
        lsp.notify(
            "textDocument/didOpen",
            {
                "textDocument": {
                    "uri": _uri(path),
                    "languageId": "cpp",
                    "version": 1,
                    "text": text,
                }
            },
        )

    # clangd only starts its background index once a file is open. Open the seed
    # files first (for --seed-only runs, open any project source as a kick) so
    # indexing begins, THEN wait for it -- call hierarchy needs the index.
    kick = list(seed_files)
    if not kick and seed_names:
        cand = sorted(glob.glob(os.path.join(root, "**", "*.cpp"), recursive=True))
        if cand:
            kick = [cand[0]]
    for p in kick:
        open_file(p)
    sys.stderr.write("lsp-graph: waiting for background index...\n")
    lsp.pump(index_timeout, until_index=True)
    time.sleep(0.5)

    def itemkey(item):
        s = item["selectionRange"]["start"]
        return "%s:%d:%d" % (item["uri"], s["line"], s["character"])

    nodes = {}  # itemkey (or "type:"+key) -> node dict, shared namespace
    edges = {}  # (src_id, tgt_id) -> edge dict

    # ---- type containment (documentSymbol) + inheritance (typeHierarchy) ----
    scanned_files = set()
    container_map = {}  # member itemkey -> (parent symbol dict, uri)
    discovered = []  # (symbol, uri) for every callable/type seen - --all seeding
    pending_type_expansion = []  # (node, sym, uri) - typeHierarchy calls, deferred

    def scan_file(path):
        """Cache the file's containment structure: for every method/ctor/function
        nested under a class/struct/interface/enum, remember its owner. clangd's
        CallHierarchyItem carries no parent-symbol info, so this is the only way
        to recover "what type does this callable belong to". Also records every
        callable/type symbol seen into `discovered`, for --all's whole-project
        seeding (a no-op list when --all isn't requested)."""
        if path in scanned_files or not os.path.exists(path):
            return
        scanned_files.add(path)
        open_file(path)
        uri = _uri(path)
        pairs = []
        _flatten_with_parent(
            lsp.request("textDocument/documentSymbol", {"textDocument": {"uri": uri}}),
            None,
            pairs,
        )
        for sym, parent in pairs:
            kind = sym.get("kind")
            if kind in KIND_CLASS or kind in TYPE_KIND_CLASS:
                discovered.append((sym, uri))
            if (
                parent is not None
                and kind in KIND_CLASS
                and parent.get("kind") in TYPE_KIND_CLASS
            ):
                s = sym["selectionRange"]["start"]
                key = "%s:%d:%d" % (uri, s["line"], s["character"])
                container_map[key] = (parent, uri)

    def type_node_for(sym, uri):
        s = sym["selectionRange"]["start"]
        key = "type:%s:%d:%d" % (uri, s["line"], s["character"])
        if key in nodes:
            return nodes[key]
        rel = os.path.relpath(_path(uri), root)
        cls = [TYPE_KIND_CLASS.get(sym.get("kind"), "class")]
        tid = "type:%s:%d:%d:%s" % (rel, s["line"], s["character"], sym["name"])
        node = {
            "id": tid,
            "label": sym["name"],
            "full": "%s\n%s:%d" % (sym["name"], rel, s["line"] + 1),
            "classes": cls,
        }
        nodes[key] = node
        # Deferred, not called here: typeHierarchy is an RPC that clangd 14 is
        # known to crash on for some real code (confirmed against orchard/), and
        # a crash takes down the whole process. Running every expansion only
        # after the call graph (the primary output) is fully built means a crash
        # here can only cost inheritance edges, never already-collected calls.
        pending_type_expansion.append((node, sym, uri))
        return node

    def expand_type_hierarchy(node, sym, uri):
        # clangd 14 speaks its pre-standardization extension (a single request
        # returns the whole parents/children chain, pre-resolved to `resolve`
        # levels deep) rather than LSP 3.17's prepareTypeHierarchy/supertypes/
        # subtypes trio - same generation gap as callHierarchy/incomingCalls-only.
        result = lsp.request(
            "textDocument/typeHierarchy",
            {
                "textDocument": {"uri": uri},
                "position": sym["selectionRange"]["start"],
                "direction": 2,  # Both (0=Children, 1=Parents, 2=Both)
                "resolve": type_depth,
            },
        )
        if not result:
            return
        _walk_type_edges(result.get("parents"), node, True)
        _walk_type_edges(result.get("children"), node, False)

    def _walk_type_edges(items, from_node, is_super):
        # `items` is already recursively resolved by clangd (nested parents/
        # children inline), so this just flattens it - no further RPCs.
        for it in items or []:
            if len(nodes) >= max_nodes:
                return
            it_uri = it.get("uri")
            s = it["selectionRange"]["start"]
            key = "type:%s:%d:%d" % (it_uri, s["line"], s["character"])
            tnode = nodes.get(key)
            if tnode is None:
                rel = os.path.relpath(_path(it_uri), root)
                cls = [TYPE_KIND_CLASS.get(it.get("kind"), "class")]
                tid = "type:%s:%d:%d:%s" % (rel, s["line"], s["character"], it["name"])
                tnode = {
                    "id": tid,
                    "label": it["name"],
                    "full": "%s\n%s:%d" % (it["name"], rel, s["line"] + 1),
                    "classes": cls,
                }
                nodes[key] = tnode
            src, tgt = (
                (from_node["id"], tnode["id"])
                if is_super
                else (tnode["id"], from_node["id"])
            )
            edges.setdefault(
                (src, tgt),
                {
                    "source": src,
                    "target": tgt,
                    "label": "inherits",
                    "classes": ["inherits"],
                },
            )
            _walk_type_edges(it.get("parents"), tnode, True)
            _walk_type_edges(it.get("children"), tnode, False)

    def link_container(item, member_node):
        path = _path(item["uri"])
        scan_file(path)
        entry = container_map.get(itemkey(item))
        if not entry:
            return
        parent_sym, uri = entry
        tnode = type_node_for(parent_sym, uri)
        edges.setdefault(
            (member_node["id"], tnode["id"]),
            {
                "source": member_node["id"],
                "target": tnode["id"],
                "label": "member of",
                "classes": ["member-of"],
            },
        )

    def node_for(item, seed=False):
        key = itemkey(item)
        if key in nodes:
            if seed and "seed" not in nodes[key]["classes"]:
                nodes[key]["classes"].append("seed")
            return nodes[key]
        rel = os.path.relpath(_path(item["uri"]), root)
        s = item["selectionRange"]["start"]
        cls = [KIND_CLASS.get(item.get("kind"), "function")]
        if seed:
            cls.append("seed")
        nid = "sym:%s:%d:%d:%s" % (rel, s["line"], s["character"], item["name"])
        detail = item.get("detail") or ""
        node = {
            "id": nid,
            "label": item["name"],
            "full": "%s\n%s\n%s:%d" % (item["name"], detail, rel, s["line"] + 1),
            "classes": cls,
        }
        nodes[key] = node
        link_container(item, node)
        return node

    # Resolve seeds -> CallHierarchyItems.
    seeds = []
    for path in seed_files:
        if not os.path.exists(path):
            sys.stderr.write("lsp-graph: no such file: %s\n" % path)
            continue
        open_file(path)
        syms = []
        _flatten(
            lsp.request(
                "textDocument/documentSymbol", {"textDocument": {"uri": _uri(path)}}
            ),
            syms,
        )
        for sym in syms:
            if sym.get("kind") not in KIND_CLASS:
                continue
            pos = sym["selectionRange"]["start"]
            items = lsp.request(
                "textDocument/prepareCallHierarchy",
                {"textDocument": {"uri": _uri(path)}, "position": pos},
            )
            seeds.extend(items or [])
    for name in seed_names:
        for sym in lsp.request("workspace/symbol", {"query": name}) or []:
            if sym.get("kind") not in KIND_CLASS:
                continue
            loc = sym.get("location", {})
            uri = loc.get("uri")
            if not uri:
                continue
            open_file(_path(uri))
            items = lsp.request(
                "textDocument/prepareCallHierarchy",
                {"textDocument": {"uri": uri}, "position": loc["range"]["start"]},
            )
            seeds.extend(items or [])

    # --all: open+documentSymbol every source file under the project, adding every
    # callable as a bulk (unmarked) BFS start and every type directly (so a bare
    # enum/struct with no methods still gets a node, not just incidental ones
    # discovered via containment).
    bulk_items = []
    if seed_all:
        files = discover_source_files(root, exclude_dirs)
        sys.stderr.write(
            "lsp-graph: --all: scanning %d source file(s)...\n" % len(files)
        )
        for path in files:
            scan_file(path)
        for sym, uri in discovered:
            kind = sym.get("kind")
            if kind in KIND_CLASS:
                bulk_items.append(
                    {
                        "uri": uri,
                        "name": sym["name"],
                        "kind": kind,
                        "selectionRange": sym["selectionRange"],
                    }
                )
            elif kind in TYPE_KIND_CLASS:
                type_node_for(sym, uri)

    if not seeds and not bulk_items:
        raise SystemExit(
            "lsp-graph: no seed symbols resolved (check --seed/--file/--all)"
        )

    # BFS up the caller graph via incomingCalls. Explicit seeds get the red
    # "seed" border; --all's bulk items don't (marking every symbol in the
    # project as "the seed" would be meaningless noise).
    queue = []
    visited = set()
    for it in seeds:
        node_for(it, seed=True)
        k = itemkey(it)
        if k not in visited:
            visited.add(k)
            queue.append((it, 0))
    for it in bulk_items:
        node_for(it, seed=False)
        k = itemkey(it)
        if k not in visited:
            visited.add(k)
            queue.append((it, 0))

    while queue and len(nodes) < max_nodes:
        item, d = queue.pop(0)
        if d >= depth:
            continue
        open_file(_path(item["uri"]))
        incoming = lsp.request("callHierarchy/incomingCalls", {"item": item}) or []
        callee = node_for(item)
        for call in incoming:
            frm = call.get("from")
            if not frm:
                continue
            if itemkey(frm) not in nodes and len(nodes) >= max_nodes:
                continue  # don't add new caller nodes past the cap
            caller = node_for(frm)
            edges[(caller["id"], callee["id"])] = {
                "source": caller["id"],
                "target": callee["id"],
                "label": "calls",
                "classes": ["call"],
            }
            k = itemkey(frm)
            if k not in visited and len(nodes) < max_nodes:
                visited.add(k)
                queue.append((frm, d + 1))

    # Now that the call graph is fully built, resolve every type's ancestors/
    # descendants. Deferred to last (see type_node_for) so a typeHierarchy crash
    # can only truncate inherits edges, not the call graph above.
    for node, sym, uri in pending_type_expansion:
        if len(nodes) >= max_nodes:
            break
        expand_type_hierarchy(node, sym, uri)

    truncated = bool(queue) or len(nodes) >= max_nodes
    return list(nodes.values()), list(edges.values()), truncated


def assemble(nodes, edges, root, seeds_desc, truncated):
    counts = {"nodes": len(nodes), "edges": len(edges), "by_type": {}, "by_class": {}}
    for n in nodes:
        for c in n["classes"]:
            counts["by_type"][c] = counts["by_type"].get(c, 0) + 1
    for e in edges:
        for c in e["classes"]:
            counts["by_class"][c] = counts["by_class"].get(c, 0) + 1
    meta = {
        "title": "calls — " + os.path.basename(os.path.abspath(root)),
        "subtitle": "seeded from " + seeds_desc,
        "host": socket.gethostname(),
        "captured": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
        "truncated": truncated,
        "counts": counts,
    }
    return {
        "meta": meta,
        "node_classes": NODE_CLASSES,
        "edge_classes": EDGE_CLASSES,
        "style": STYLE,
        "edge_key": EDGE_KEY,
        "traversals": TRAVERSALS,
        "force_structures": FORCE_STRUCTURES,
        "nodes": nodes,
        "edges": edges,
    }


def find_compile_commands(project, override):
    if override:
        return override
    if os.path.exists(os.path.join(project, "compile_commands.json")):
        return project
    for d in sorted(glob.glob(os.path.join(project, "build*"))):
        if os.path.exists(os.path.join(d, "compile_commands.json")):
            return d
    return None


def main():
    ap = argparse.ArgumentParser(
        prog="lsp-graph",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description=(
            "Drive a language server (clangd) and emit a call-graph model JSON for\n"
            "the socketscope viewer. The graph is built by walking callers\n"
            "(incomingCalls) up from the seed symbols. Pipe to: render-graph-html.py"
        ),
        epilog=(
            "examples:\n"
            "  lsp-graph proj --file src/foo.cpp | render-graph-html.py > calls.html\n"
            "  lsp-graph proj --seed planPath --depth 4 | render-graph-html.py\n"
            "  lsp-graph proj --all --max-nodes 5000 | render-graph-html.py\n"
        ),
    )
    ap.add_argument(
        "project",
        help="project root (contains, or has a build dir with, compile_commands.json)",
    )
    ap.add_argument(
        "--seed",
        action="append",
        default=[],
        metavar="NAME",
        help="seed symbol name (workspace/symbol); repeatable",
    )
    ap.add_argument(
        "--file",
        action="append",
        default=[],
        metavar="PATH",
        help="seed from every function in PATH; repeatable",
    )
    ap.add_argument(
        "--all",
        action="store_true",
        help="seed from every function/type in the project (walks every source "
        "file's documentSymbol) for a whole-project graph; combine with a "
        "larger --max-nodes",
    )
    ap.add_argument(
        "--exclude-dir",
        action="append",
        default=[],
        metavar="NAME",
        help="with --all, also skip this directory name (repeatable); "
        "third_party/vendor/etc. are already skipped by default",
    )
    ap.add_argument(
        "--depth",
        type=int,
        default=3,
        metavar="N",
        help="caller BFS hops from the seeds (default: 3)",
    )
    ap.add_argument(
        "--max-nodes",
        type=int,
        default=400,
        metavar="N",
        help="cap total symbols (default: 400)",
    )
    ap.add_argument(
        "--type-depth",
        type=int,
        default=3,
        metavar="N",
        help="ancestor/descendant hops to resolve per type via typeHierarchy (default: 3)",
    )
    ap.add_argument(
        "--compile-commands",
        default=None,
        metavar="DIR",
        help="dir with compile_commands.json (default: autodetect under the project)",
    )
    ap.add_argument(
        "--server",
        default="clangd",
        metavar="CMD",
        help="language server command (default: clangd)",
    )
    ap.add_argument(
        "--index-timeout",
        type=int,
        default=60,
        metavar="S",
        help="seconds to wait for the background index (default: 60)",
    )
    args = ap.parse_args()

    project = os.path.abspath(args.project)
    if not os.path.isdir(project):
        ap.error("not a directory: %s" % args.project)
    if not args.seed and not args.file and not args.all:
        ap.error("give at least one --seed NAME, --file PATH, or --all")

    cmd = [args.server]
    if "clangd" in os.path.basename(args.server):
        cmd += ["--background-index", "--log=error"]
        cc = find_compile_commands(project, args.compile_commands)
        if cc:
            cmd.append("--compile-commands-dir=" + cc)
        else:
            sys.stderr.write(
                "lsp-graph: warning: no compile_commands.json found under %s\n"
                % project
            )

    lsp = LSP(cmd)
    try:
        ok = lsp.request(
            "initialize",
            {
                "processId": os.getpid(),
                "rootUri": _uri(project),
                "capabilities": {
                    "textDocument": {
                        "callHierarchy": {"dynamicRegistration": True},
                        "documentSymbol": {"hierarchicalDocumentSymbolSupport": True},
                    },
                    "window": {"workDoneProgress": True},
                },
            },
        )
        if ok is None:
            raise SystemExit("lsp-graph: server failed to initialize")
        lsp.notify("initialized", {})

        # --file may be given relative to cwd or to the project root.
        seed_files = [
            os.path.abspath(p if os.path.exists(p) else os.path.join(project, p))
            for p in args.file
        ]
        nodes, edges, truncated = build_callgraph(
            lsp,
            project,
            args.seed,
            seed_files,
            args.all,
            args.exclude_dir,
            args.depth,
            args.max_nodes,
            args.index_timeout,
            args.type_depth,
        )
    finally:
        lsp.shutdown()

    seeds_desc = ", ".join(args.seed + [os.path.basename(p) for p in args.file])
    if args.all:
        seeds_desc = (seeds_desc + ", " if seeds_desc else "") + "whole project (--all)"
    seeds_desc = seeds_desc or "?"
    model = assemble(nodes, edges, project, seeds_desc, truncated)
    json.dump(model, sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
    c = model["meta"]["counts"]
    sys.stderr.write(
        "lsp-graph: %s — %d nodes, %d edges%s\n"
        % (
            model["meta"]["title"],
            c["nodes"],
            c["edges"],
            " [truncated]" if truncated else "",
        )
    )


if __name__ == "__main__":
    main()
